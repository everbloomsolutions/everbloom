{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "tsconfig.json",
    ".env",
    ".env.local",
    "pnpm-lock.yaml"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        "build/**",
        ".next/**",
        "!.next/cache/**"
      ],
      "env": [
        "NODE_ENV",
        "VITE_API_BASE_URL",
        "VITE_SOCKET_URL",
        "VITE_APP_NAME",
        "VITE_APP_VERSION",
        "VITE_BACKEND_URL",
        "VITE_BACKEND_PORT",
        "VITE_DEV_PORT"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": [
        "build"
      ],
      "outputs": [
        "coverage/**"
      ],
      "env": [
        "NODE_ENV",
        "TEST_MONGODB_URI",
        "VITE_API_BASE_URL",
        "VITE_SOCKET_URL"
      ]
    },
    "lint": {
      "outputs": []
    },
    "type-check": {
      "outputs": [],
      "dependsOn": [
        "^build"
      ]
    },
    "clean": {
      "cache": false
    },
    "start": {
      "cache": false
    },
    "preview": {
      "cache": false,
      "persistent": true
    },
    "create-admin": {
      "cache": false,
      "env": [
        "MONGODB_URI",
        "NODE_ENV"
      ]
    },
    "validate:env": {
      "cache": false,
      "env": [
        "VITE_API_BASE_URL",
        "VITE_SOCKET_URL"
      ]
    }
  }
}
