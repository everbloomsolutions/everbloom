# =============================================================================
# Backend Environment Variables
# =============================================================================
#
# Copy this file to .env and configure your environment variables
#
# For local development, create .env in this directory (back-end/.env)
# For production, set these variables in your deployment platform.
#
# =============================================================================

# Environment
# NODE_ENV=development

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
#
# Port Configuration Priority:
# 1. PORT - Highest priority (set by container platforms)
#    - Server automatically binds to 0.0.0.0 when PORT is set
#
# 2. BACKEND_PORT (Manual override for local development/testing)
#    - Use this for local development when you want a specific port
#    - Example: BACKEND_PORT=3000 (to match frontend expectations)
#    - Example: BACKEND_PORT=8080 (default development port)
#
# 3. Default: 8080 (Development fallback)
#    - Used when neither PORT nor BACKEND_PORT is set
#
# Local Development:
# - Defaults to port 8080 on localhost
# - Can override with BACKEND_PORT=3000 for consistency with frontend
# - Host defaults to 'localhost' for security
#
# BACKEND_PORT=8080  # Local development (default)
# BACKEND_PORT=3000  # Alternative: match frontend expectations
# BACKEND_HOST=localhost  # Local development only (ignored when PORT is set)

# Logging
# LOG_LEVEL=debug

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
#
# IMPORTANT: Use different services for development vs production
#
# Development (Local Docker):
#   - Uses local MongoDB container (MONGO_INITDB_DATABASE=everbloom in docker-compose.dev.yaml)
#   - Start with: docker compose -f docker-compose.dev.yaml up -d (or ./scripts/docker-dev.sh up)
#   - Default: mongodb://localhost:27017/everbloom
#
# Production (MongoDB Atlas):
#   - REQUIRED: Use MongoDB Atlas cloud service
#   - Get connection string from: https://cloud.mongodb.com/
#   - Format: mongodb+srv://username:password@cluster.mongodb.net/everbloom?retryWrites=true&w=majority
#   - MUST NOT use localhost in production
#
# MONGODB_URI=mongodb://localhost:27017/everbloom  # Development (aligns with docker-compose.dev.yaml)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/everbloom?retryWrites=true&w=majority  # Production

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
#
# IMPORTANT: Use different services for development vs production
#
# Development (Local Docker):
#   - Uses local Redis container running in Docker
#   - Start with: docker-compose -f docker-compose.dev.yaml up -d redis
#   - Default: redis://localhost:6379
#
# Production (Upstash Redis):
#   - REQUIRED: Use Upstash Redis cloud service
#   - Get connection string from: https://console.upstash.com/
#   - Format: rediss://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:YOUR_PORT
#   - Note: Use rediss:// (with double 's') for TLS/SSL connection
#   - MUST NOT use localhost in production
#
# REDIS_URL=redis://localhost:6379  # Development
# REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:YOUR_PORT  # Production

# =============================================================================
# JWT CONFIGURATION
# =============================================================================

# JWT_SECRET=your-secret-key-here
# JWT_REFRESH_SECRET=your-refresh-secret-key-here
# JWT_EXPIRES_IN=7d
# JWT_REFRESH_EXPIRES_IN=30d

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# BACKEND_CORS_ORIGIN=http://localhost:3001,http://localhost:3000
# ADMIN_PANEL_URL=http://localhost:3001


# Email Configuration (SMTP)
# For Gmail: Use App Password (not regular password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# For other providers:
# - Outlook/Hotmail: smtp-mail.outlook.com:587
# - Yahoo: smtp.mail.yahoo.com:587
# - SendGrid: smtp.sendgrid.net:587 (use API key as password)
# - Mailgun: smtp.mailgun.org:587
