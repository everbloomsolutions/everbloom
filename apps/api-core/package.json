{
  "name": "@everbloom/api-core",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "main": "dist/main.js",
  "scripts": {
    "dev": "NODE_OPTIONS=--max-old-space-size=8192 nest start --watch",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "test": "vitest",
    "lint": "eslint .",
    "type-check": "NODE_OPTIONS=--max-old-space-size=8192 tsc -p tsconfig.build.json --noEmit && NODE_OPTIONS=--max-old-space-size=8192 tsc -p tsconfig.eslint.json --noEmit",
    "clean": "rm -rf dist .turbo coverage .cache",
    "clean:cache": "rm -rf dist .turbo coverage .cache && pnpm store prune",
    "clean:all": "pnpm clean && rm -rf node_modules && pnpm store prune",
    "turbo:build": "turbo build --filter=@everbloom/api-core",
    "turbo:dev": "turbo dev --filter=@everbloom/api-core",
    "turbo:test": "turbo test --filter=@everbloom/api-core",
    "turbo:lint": "turbo lint --filter=@everbloom/api-core",
    "turbo:type-check": "turbo type-check --filter=@everbloom/api-core",
    "create-admin": "tsx scripts/create-admin.ts",
    "create-agent": "tsx scripts/create-agent.ts",
    "check-and-create-admin": "tsx scripts/check-and-create-admin.ts",
    "check-and-create-super-admin": "tsx scripts/check-and-create-super-admin.ts",
    "list-admin-users": "tsx scripts/list-admin-users.ts",
    "list-users:prod": "tsx scripts/list-users-production.ts",
    "check-db-schema:prod": "tsx scripts/check-db-schema.ts",
    "kill-ports": "node ../../scripts/kill-dev-ports.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@nestjs/bull": "^10.1.1",
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.10",
    "@nestjs/mongoose": "^10.0.2",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/platform-socket.io": "^10.3.10",
    "@nestjs/websockets": "^10.3.10",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.8.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.6.0",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.11",
    "pdfkit": "^0.17.2",
    "redis": "^5.10.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "xlsx": "^0.18.5",
    "xss": "^1.0.15",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@nestjs/cli": "^10.4.8",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.4.22",
    "@swc/core": "^1.15.46",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/csv-parse": "^1.2.5",
    "@types/csv-stringify": "^3.1.3",
    "@types/express": "^4.17.21",
    "@types/helmet": "^0.0.48",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^7.0.4",
    "@types/pdfkit": "^0.17.4",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vercel/node": "^3.0.7",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "kill-port": "^1.0.1",
    "supertest": "^7.1.4",
    "tsx": "^4.7.0",
    "turbo": "^2.3.3",
    "typescript": "^5.3.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.0.15"
  }
}
