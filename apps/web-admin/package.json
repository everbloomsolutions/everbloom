{
  "name": "@everbloom/web-admin",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' vite",
    "build": "vite build",
    "start": "vite preview --host 0.0.0.0 --port ${PORT:-3000}",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .vite node_modules/.vite .turbo",
    "clean:all": "pnpm clean && rm -rf node_modules && pnpm store prune",
    "prebuild": "node scripts/validate-env.js && node -e \"if (!require('fs').existsSync('pnpm-lock.yaml')) { console.warn('⚠️  pnpm-lock.yaml not found. Run: pnpm install'); }\"",
    "validate:env": "node scripts/validate-env.js",
    "docker:build": "docker build -f ../../docker/Dockerfile.web-admin -t ghcr.io/everbloom/web-admin:latest ../..",
    "docker:up": "docker compose -f ../../docker-compose.dev.yaml up -d",
    "docker:down": "docker compose -f ../../docker-compose.dev.yaml down"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "chart.js": "^4.4.1",
    "clsx": "^2.1.0",
    "date-fns": "^3.0.6",
    "lucide-react": "^0.344.0",
    "react": "^18.3.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.20.1",
    "react-window": "^2.2.5",
    "@tanstack/react-query": "^5.0.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/ui": "^4.0.15",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.15",
    "globals": "^16.5.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "turbo": "^2.3.3",
    "typescript": "^5.3.3",
    "vite": "^7.2.7",
    "vite-plugin-terminal": "^1.3.0",
    "vitest": "^4.0.15"
  }
}
